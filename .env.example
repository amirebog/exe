# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: protect webhook endpoint
TELEGRAM_WEBHOOK_SECRET=

# Cron job auth (Vercel Cron)
CRON_SECRET=

# Optional: protect full stats API (public stats use ?public=1)
STATS_SECRET=

# Optional: Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional: Google Search Console
GOOGLE_SITE_VERIFICATION=

# Site URL for webhook setup script
SITE_URL=https://zyrixx.vercel.app
